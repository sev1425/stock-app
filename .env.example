# Copy to .env for `vercel dev` (server reads this). Never commit real keys.
FINNHUB_API_KEY=

# Optional: deployed app origin when running only `npm start` (browser calls this URL for /api).
# Example: https://your-project.vercel.app
# REACT_APP_API_BASE_URL=

# Optional: proxy /api from CRA to local serverless (run `npx vercel dev --listen 3001` in another terminal).
# PROXY_API_TARGET=http://127.0.0.1:3001
